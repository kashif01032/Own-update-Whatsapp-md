# =============================================
# 🚀 WhatsApp Bot Environment Configuration
# =============================================
#
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# =============================================

# 📱 WhatsApp Phone Number (Optional)
# If set, the bot will use this number for pairing code generation
# If not set, the bot will ask you to enter the number interactively
# Format: Country code + phone number (e.g., 923143007893 for Pakistan)
PHONE_NUMBER=923143007893

# =============================================
# OPTIONAL: Railway/Deployment Variables
# =============================================
# If deploying on Railway, Render, or other platforms,
# set PHONE_NUMBER in your platform's environment variables
# to avoid interactive prompts
# =============================================
